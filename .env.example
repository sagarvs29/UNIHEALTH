# =============================================
# UniHealth ID — Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file
# =============================================

# ---- DATABASE (Supabase) ----
# Get from: https://supabase.com → Project Settings → Database → Connection String
# Use the "Transaction" pooler URL for DATABASE_URL
# Use the "Session" pooler or direct URL for DIRECT_URL
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres"

# ---- JWT AUTH ----
# Generate strong secrets: run  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace-with-64-char-random-string"
JWT_REFRESH_SECRET="replace-with-different-64-char-random-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ---- REDIS (Upstash) ----
# Get from: https://console.upstash.com → Your Redis DB → REST API
UPSTASH_REDIS_REST_URL="https://your-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ---- FILE STORAGE (Cloudinary) ----
# Get from: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ---- AI SERVICES ----
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."
# Google Gemini (fallback): https://aistudio.google.com/app/apikey
GEMINI_API_KEY="AIza..."

# ---- APP CONFIG ----
PORT=5000
NODE_ENV="development"
CLIENT_URL="http://localhost:5173"

# ---- OTP / EMAIL (Nodemailer) ----
# Use Gmail App Password (not your real password)
# Gmail → Google Account → Security → 2FA → App Passwords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-gmail@gmail.com"
SMTP_PASS="your-16-char-app-password"
EMAIL_FROM="UniHealth ID <your-gmail@gmail.com>"

# ---- ENCRYPTION ----
# For Aadhaar AES-256 encryption - 32 bytes = 64 hex chars
ENCRYPTION_KEY="replace-with-64-char-hex-string"
ENCRYPTION_IV="replace-with-32-char-hex-string"

# =============================================
# AI SERVICE (apps/ai) uses these same keys:
# OPENAI_API_KEY, GEMINI_API_KEY
# Add these to apps/ai/.env as well
# =============================================
