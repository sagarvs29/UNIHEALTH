# =============================================
# UniHealth ID (UHID) — .gitignore
# =============================================

# ---- Dependencies ----
node_modules/
.pnp
.pnp.js

# ---- Environment Variables (NEVER commit these) ----
.env
.env.local
.env.development
.env.production
apps/api/.env
apps/web/.env
apps/ai/.env

# ---- Build Outputs ----
dist/
build/
out/
.next/

# ---- TypeScript ----
*.tsbuildinfo

# ---- Prisma ----
# Keep schema.prisma but ignore generated client
apps/api/node_modules/.prisma/

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.pyc
.venv/
venv/
env/
.Python
*.egg-info/
dist/
*.egg

# ---- Logs ----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- OS Files ----
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ---- IDE ----
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---- Testing ----
coverage/
.nyc_output/

# ---- Misc ----
*.pem
.vercel
.render
