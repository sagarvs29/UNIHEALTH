// ============================================================
// UniHealth ID (UHID) — Prisma Schema
// Database: PostgreSQL 15 (Supabase)
// ORM: Prisma 5
// Version: 1.0
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // directUrl removed — session pooler handles both app + migrations on IPv4 networks
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  PATIENT
  DOCTOR
  HOSPITAL_STAFF
  HOSPITAL_ADMIN
  INSURANCE_PROVIDER
}

enum BloodGroup {
  A_POS
  A_NEG
  B_POS
  B_NEG
  O_POS
  O_NEG
  AB_POS
  AB_NEG
  UNKNOWN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum RecordType {
  LAB_REPORT
  IMAGING
  PRESCRIPTION
  DISCHARGE_SUMMARY
  VACCINATION
  ECG
  OTHER
}

enum RecordSubType {
  // Lab Report subtypes
  CBC                  // Complete Blood Count
  LIPID_PROFILE
  LFT                  // Liver Function Test
  KFT                  // Kidney Function Test
  HBA1C
  THYROID_PROFILE
  BLOOD_SUGAR
  URINE_ROUTINE
  // Imaging subtypes
  XRAY
  MRI
  CT_SCAN
  ULTRASOUND
  PET_SCAN
  // ECG / Other
  ECG_REPORT
  OTHER
}

enum ConsentStatus {
  PENDING    // Patient has not yet approved
  ACTIVE     // Patient approved, currently valid
  REVOKED    // Patient manually revoked
  EXPIRED    // Past the expiry date/time
}

enum ConsentGrantedToType {
  DOCTOR
  INSURANCE_PROVIDER
}

enum EmergencyAccessType {
  SOS_ACTIVATED    // Patient triggered SOS
  DOCTOR_OVERRIDE  // Doctor bypassed consent in emergency
}

enum ClaimStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  ON_HOLD
}

enum ClaimType {
  HOSPITALIZATION
  OUTPATIENT
  SURGERY
  MEDICATION
  DIAGNOSTIC
  OTHER
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum FamilyAccessType {
  VIEW         // Can only view records
  MANAGE       // Can manage appointments, consents
  FULL_CONTROL // Full access (for guardians/parents of minors)
}

enum InteractionSeverity {
  LOW
  MODERATE
  HIGH
  CRITICAL
}

enum StaffType {
  RECEPTIONIST
  LAB_TECHNICIAN
  NURSE
  PHARMACIST
  RADIOLOGIST
  ADMIN_STAFF
}

enum AuditAction {
  // Auth
  LOGIN
  LOGOUT
  REGISTER
  PASSWORD_CHANGE
  // Records
  VIEW_RECORD
  UPLOAD_RECORD
  DELETE_RECORD
  DOWNLOAD_RECORD
  // Prescription
  ADD_PRESCRIPTION
  UPDATE_PRESCRIPTION
  PHARMA_CHECK
  PHARMA_OVERRIDE
  // Consent
  REQUEST_CONSENT
  GRANT_CONSENT
  REVOKE_CONSENT
  CONSENT_EXPIRED
  // Emergency
  SOS_ACTIVATED
  SOS_DEACTIVATED
  EMERGENCY_ACCESS
  EMERGENCY_OVERRIDE
  // Insurance
  SUBMIT_CLAIM
  APPROVE_CLAIM
  REJECT_CLAIM
  REQUEST_RECORDS
  // Admin
  ADD_STAFF
  REMOVE_STAFF
  SUSPEND_STAFF
  VERIFY_DOCTOR
  // QR
  GENERATE_QR
  SCAN_QR
  // AI
  AI_REPORT_DECODE
  AI_CLINICAL_SUMMARY
  // Appointment
  BOOK_APPOINTMENT
  CANCEL_APPOINTMENT
}

// ============================================================
// CORE AUTHENTICATION
// ============================================================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  phone        String?  @unique
  passwordHash String
  role         Role
  isVerified   Boolean  @default(false)
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Role-specific profiles (only one will be set based on role)
  patient           Patient?
  doctor            Doctor?
  hospitalStaff     HospitalStaff?
  hospitalAdmin     HospitalAdmin?
  insuranceProvider InsuranceProvider?

  // Audit logs generated by this user
  auditLogs AuditLog[]

  @@map("users")
}

// ============================================================
// ROLE PROFILES
// ============================================================

model Patient {
  id              String     @id @default(cuid())
  uhid            String     @unique // e.g. "UH-847291" — 6-digit unique
  userId          String     @unique
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Personal Info
  firstName       String
  lastName        String
  dateOfBirth     DateTime
  gender          Gender
  profilePhotoUrl String?    // Cloudinary URL

  // Medical Identity
  bloodGroup      BloodGroup @default(UNKNOWN)
  allergies       String[]   // e.g. ["Penicillin", "Dust", "Peanuts"]
  chronicConditions String[] // e.g. ["Diabetes Type 2", "Hypertension"]
  currentMedications String[] // e.g. ["Metformin 500mg", "Amlodipine 5mg"]

  // Physical Stats
  heightCm        Float?
  weightKg        Float?

  // Identity (encrypted at application level before storing)
  aadhaarEncrypted String?   // AES-256 encrypted Aadhaar number

  // Emergency Info
  emergencyContacts EmergencyContact[]

  // SOS Status
  isSosActive     Boolean    @default(false)
  sosActivatedAt  DateTime?

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Relations
  medicalRecords  MedicalRecord[]
  prescriptions   Prescription[]
  clinicalNotes   ClinicalNote[]
  consents        Consent[]
  qrCodes         QRCode[]
  emergencyAccesses EmergencyAccess[]
  insuranceClaims InsuranceClaim[]
  appointments    Appointment[]

  // Family links
  primaryFamilyLinks FamilyLink[] @relation("PrimaryPatient")
  linkedFamilyLinks  FamilyLink[] @relation("LinkedPatient")

  @@map("patients")
}

model Doctor {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Professional Info
  firstName       String
  lastName        String
  licenseNumber   String   @unique // Medical council registration number
  specialty       String   // e.g. "Cardiology", "General Medicine"
  subSpecialty    String?
  qualifications  String[] // e.g. ["MBBS", "MD", "DM Cardiology"]
  profilePhotoUrl String?

  // Hospital Association
  hospitalId      String
  hospital        Hospital @relation(fields: [hospitalId], references: [id])
  department      String?  // e.g. "Cardiology Department"

  // Verification
  isVerified      Boolean  @default(false) // Verified by Hospital Admin
  verifiedAt      DateTime?
  verifiedBy      String?  // HospitalAdmin userId

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  prescriptions   Prescription[]
  clinicalNotes   ClinicalNote[]
  consentsGranted Consent[]      @relation("ConsentGrantedToDoctor")
  emergencyAccesses EmergencyAccess[]
  pharmaCheckLogs PharmaCheckLog[]
  appointments    Appointment[]

  @@map("doctors")
}

model HospitalStaff {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName    String
  lastName     String
  staffType    StaffType
  department   String?   // e.g. "Pathology Lab", "Radiology"
  employeeId   String?   // Hospital internal employee ID

  hospitalId   String
  hospital     Hospital  @relation(fields: [hospitalId], references: [id])

  isVerified   Boolean   @default(false)
  verifiedAt   DateTime?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  uploadedRecords MedicalRecord[]

  @@map("hospital_staff")
}

model HospitalAdmin {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName  String
  lastName   String

  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("hospital_admins")
}

model InsuranceProvider {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Agent Info
  firstName   String
  lastName    String
  agentId     String   @unique // Internal agent ID

  // Company Info
  companyName String   // e.g. "Star Health Insurance"
  companyCode String?  // Insurer registration code

  isVerified  Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  consentsGranted Consent[]      @relation("ConsentGrantedToInsurance")
  insuranceClaims InsuranceClaim[]

  @@map("insurance_providers")
}

// ============================================================
// HOSPITAL
// ============================================================

model Hospital {
  id           String   @id @default(cuid())
  name         String
  registrationNumber String? @unique // Govt registration
  address      String
  city         String
  state        String
  pincode      String
  phone        String
  email        String?
  website      String?
  logoUrl      String?  // Cloudinary URL
  isVerified   Boolean  @default(false)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  doctors      Doctor[]
  staff        HospitalStaff[]
  admins       HospitalAdmin[]
  medicalRecords MedicalRecord[]

  @@map("hospitals")
}

// ============================================================
// EMERGENCY CONTACTS
// ============================================================

model EmergencyContact {
  id           String  @id @default(cuid())
  patientId    String
  patient      Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  name         String
  phone        String
  relationship String  // e.g. "Spouse", "Father", "Friend"
  isPrimary    Boolean @default(false)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("emergency_contacts")
}

// ============================================================
// MEDICAL RECORDS
// ============================================================

model MedicalRecord {
  id              String        @id @default(cuid())
  patientId       String
  patient         Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)

  // Record Classification
  recordType      RecordType
  recordSubType   RecordSubType?
  title           String        // e.g. "CBC Report - Jan 2025"
  description     String?

  // File Storage (Cloudinary)
  fileUrl         String        // Cloudinary secure URL
  filePublicId    String        // Cloudinary public ID (for deletion)
  fileMimeType    String        // e.g. "application/pdf", "image/jpeg"
  fileSizeBytes   Int?

  // OCR / AI extracted data (flexible JSONB)
  // For lab reports: { "hemoglobin": "14.2 g/dL", "wbc": "7800 cells/µL", ... }
  // For imaging: { "findings": "No acute abnormality", "impression": "Normal CXR" }
  extractedData   Json?

  // AI Summary (cached)
  aiSummary       AIReportSummary?

  // Metadata
  testDate        DateTime?     // Date the test was performed
  labName         String?       // Name of the lab/hospital that did the test
  referringDoctorId String?     // Doctor who ordered this test
  uploadedByStaffId String?     // HospitalStaff who uploaded
  uploadedByStaff   HospitalStaff? @relation(fields: [uploadedByStaffId], references: [id])
  hospitalId      String?
  hospital        Hospital?     @relation(fields: [hospitalId], references: [id])

  // Blockchain verification badge
  blockchainHash  String?       // Optional future feature
  isVerified      Boolean       @default(false)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  claimDocuments  ClaimDocument[]

  @@map("medical_records")
}

// ============================================================
// PRESCRIPTIONS
// ============================================================

model Prescription {
  id                 String    @id @default(cuid())
  patientId          String
  patient            Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId           String
  doctor             Doctor    @relation(fields: [doctorId], references: [id])

  visitDate          DateTime  @default(now())
  diagnosis          String?   // Brief diagnosis note
  notes              String?   // Additional instructions (e.g. "Take after meals")

  // Pharma-Check tracking
  pharmaCheckDone    Boolean   @default(false)
  pharmaCheckResult  Json?     // Snapshot of interaction check result
  hasInteractions    Boolean   @default(false)
  overridden         Boolean   @default(false) // Doctor overrode interaction warning
  overrideReason     String?

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations
  items              PrescriptionItem[]
  pharmaCheckLogs    PharmaCheckLog[]

  @@map("prescriptions")
}

model PrescriptionItem {
  id             String       @id @default(cuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  medicineName   String       // e.g. "Metformin"
  genericName    String?      // e.g. "Metformin Hydrochloride"
  dosage         String       // e.g. "500mg"
  frequency      String       // e.g. "Twice daily"
  duration       String       // e.g. "30 days"
  route          String?      // e.g. "Oral", "IV", "Topical"
  instructions   String?      // e.g. "Take with food"
  rxcui          String?      // RxNorm Concept Unique Identifier

  createdAt      DateTime     @default(now())

  @@map("prescription_items")
}

// ============================================================
// CLINICAL NOTES
// ============================================================

model ClinicalNote {
  id              String   @id @default(cuid())
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId        String
  doctor          Doctor   @relation(fields: [doctorId], references: [id])

  visitDate       DateTime @default(now())
  visitType       String   // e.g. "OPD", "IPD", "Telehealth", "Emergency"

  // Clinical Details
  chiefComplaint  String   // Patient's main complaint
  historyOfPresentIllness String?
  examinationFindings String?
  vitalSigns      Json?    // { "bp": "120/80", "pulse": "72", "temp": "98.6°F", "spo2": "99%" }

  // Diagnosis
  icd10Code       String?  // e.g. "E11" for Type 2 Diabetes
  diagnosisName   String?  // e.g. "Type 2 Diabetes Mellitus"
  differentialDiagnosis String?

  treatmentPlan   String?
  followUpDate    DateTime?
  followUpNotes   String?

  isConfidential  Boolean  @default(false) // Some notes may be restricted

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("clinical_notes")
}

// ============================================================
// CONSENT MANAGEMENT
// ============================================================

model Consent {
  id               String               @id @default(cuid())
  patientId        String
  patient          Patient              @relation(fields: [patientId], references: [id], onDelete: Cascade)

  // Who is receiving access
  grantedToType    ConsentGrantedToType
  // For doctor consent
  doctorId         String?
  doctor           Doctor?              @relation("ConsentGrantedToDoctor", fields: [doctorId], references: [id])
  // For insurance consent
  insuranceProviderId String?
  insuranceProvider InsuranceProvider?  @relation("ConsentGrantedToInsurance", fields: [insuranceProviderId], references: [id])

  // Scope of access
  // e.g. ["LAB_REPORT", "IMAGING"] or ["ALL"] or ["PRESCRIPTION", "CLINICAL_NOTES"]
  scope            String[]

  // Consent terms
  purpose          String               // e.g. "Treatment", "Insurance Claim", "Second Opinion"
  status           ConsentStatus        @default(PENDING)
  isTemporary      Boolean              @default(true)
  durationHours    Int?                 // For temporary consents (e.g. 2 hours)
  expiresAt        DateTime?

  // OTP verification
  otpVerified      Boolean              @default(false)
  otpVerifiedAt    DateTime?

  // Timestamps
  requestedAt      DateTime             @default(now())
  grantedAt        DateTime?
  revokedAt        DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@map("consents")
}

// ============================================================
// QR CODES
// ============================================================

model QRCode {
  id          String   @id @default(cuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  // QR content (encrypted access code)
  accessCode  String   @unique // Short unique code embedded in QR
  qrImageUrl  String?           // Cloudinary URL of generated QR image

  // What this QR grants access to
  // e.g. ["BLOOD_GROUP", "ALLERGIES", "EMERGENCY_CONTACTS"] or ["ALL_CRITICAL"]
  scope       String[]

  // Validity
  expiresAt   DateTime
  isRevoked   Boolean  @default(false)
  revokedAt   DateTime?

  // Usage tracking
  scanCount   Int      @default(0)
  lastScannedAt DateTime?

  // Type: emergency QR card vs doctor session QR
  qrType      String   @default("DOCTOR_SESSION") // "DOCTOR_SESSION" | "EMERGENCY_CARD"

  createdAt   DateTime @default(now())

  @@map("qr_codes")
}

// ============================================================
// EMERGENCY ACCESS
// ============================================================

model EmergencyAccess {
  id           String              @id @default(cuid())
  patientId    String
  patient      Patient             @relation(fields: [patientId], references: [id], onDelete: Cascade)

  accessType   EmergencyAccessType

  // For DOCTOR_OVERRIDE: who accessed
  doctorId     String?
  doctor       Doctor?             @relation(fields: [doctorId], references: [id])

  // Emergency details
  reason       String              // Why emergency access was requested
  accessCode   String?             // Temporary code for SOS access
  location     String?             // Optional GPS/location

  // Session window
  activatedAt  DateTime            @default(now())
  expiresAt    DateTime            // Usually activatedAt + 2 hours
  terminatedAt DateTime?           // If manually terminated early

  // Patient notification
  patientNotified Boolean          @default(false)
  notifiedAt      DateTime?

  createdAt    DateTime            @default(now())

  @@map("emergency_accesses")
}

// ============================================================
// PHARMA-CHECK
// ============================================================

model PharmaCheckLog {
  id              String              @id @default(cuid())

  prescriptionId  String
  prescription    Prescription        @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  doctorId        String
  doctor          Doctor              @relation(fields: [doctorId], references: [id])

  // The new drug being added
  newDrug         String              // e.g. "Warfarin 5mg"
  newDrugRxcui    String?             // RxNorm ID

  // What was checked against
  // Array of existing drugs: ["Aspirin 75mg", "Metformin 500mg"]
  checkedAgainstDrugs Json            // string[]

  // Result
  // { interactions: [{drug1: "Warfarin", drug2: "Aspirin", effect: "...", severity: "HIGH"}] }
  interactionResult   Json

  severity        InteractionSeverity
  interactionCount Int                @default(0)

  // Drug-Allergy check
  allergyConflicts Json?              // e.g. [{ drug: "Penicillin", allergy: "Penicillin" }]

  // Drug-Condition check
  conditionConflicts Json?            // e.g. [{ drug: "NSAID", condition: "Kidney Disease" }]

  // Override
  overridden      Boolean             @default(false)
  overrideReason  String?
  overriddenAt    DateTime?

  createdAt       DateTime            @default(now())

  @@map("pharma_check_logs")
}

// ============================================================
// AI REPORT SUMMARY (cached)
// ============================================================

model AIReportSummary {
  id              String        @id @default(cuid())
  recordId        String        @unique
  record          MedicalRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  // Plain-language summary for patients
  // e.g. "Your hemoglobin is slightly low (12.1 g/dL, normal is 13.5–17.5 g/dL for men)..."
  summaryText     String

  // Structured simplified values
  // { "Hemoglobin": { value: "12.1", unit: "g/dL", normal: "13.5-17.5", status: "LOW" }, ... }
  simplifiedValues Json?

  // Overall risk level based on the report
  riskLevel       String        // "NORMAL" | "BORDERLINE" | "ABNORMAL" | "CRITICAL"

  // Model used
  modelUsed       String        @default("gpt-4o") // "gpt-4o" | "gemini-pro"

  generatedAt     DateTime      @default(now())
  // Cache invalidation: regenerate if record updated after this
  cacheValidUntil DateTime?

  @@map("ai_report_summaries")
}

// ============================================================
// INSURANCE CLAIMS
// ============================================================

model InsuranceClaim {
  id                  String            @id @default(cuid())
  claimNumber         String            @unique // Auto-generated e.g. "CLM-2025-001234"

  patientId           String
  patient             Patient           @relation(fields: [patientId], references: [id])

  insuranceProviderId String
  insuranceProvider   InsuranceProvider @relation(fields: [insuranceProviderId], references: [id])

  // Claim Details
  claimType           ClaimType
  policyNumber        String
  claimedAmount       Decimal           @db.Decimal(12, 2)
  eligibleAmount      Decimal?          @db.Decimal(12, 2)
  approvedAmount      Decimal?          @db.Decimal(12, 2)

  status              ClaimStatus       @default(PENDING)

  // Hospital & dates
  hospitalName        String?
  admissionDate       DateTime?
  dischargeDate       DateTime?
  treatmentDescription String?

  // Review
  reviewNotes         String?
  reviewedBy          String?   // InsuranceProvider userId
  reviewedAt          DateTime?

  // AI fraud check
  fraudCheckResult    Json?     // { "score": 0.12, "flags": [], "verdict": "CLEAN" }
  fraudCheckAt        DateTime?

  submittedAt         DateTime  @default(now())
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  documents           ClaimDocument[]

  @@map("insurance_claims")
}

model ClaimDocument {
  id             String         @id @default(cuid())
  claimId        String
  claim          InsuranceClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  // Link to actual medical record
  recordId       String
  record         MedicalRecord  @relation(fields: [recordId], references: [id])

  // Verification
  isVerified     Boolean        @default(false)
  verifiedAt     DateTime?
  verificationNote String?

  addedAt        DateTime       @default(now())

  @@map("claim_documents")
}

// ============================================================
// AUDIT LOGS
// ============================================================

model AuditLog {
  id         String      @id @default(cuid())

  // Who performed the action
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  userRole   Role

  // What was done
  action     AuditAction

  // On which patient (optional — not all actions are patient-related)
  patientId  String?

  // Additional context
  // e.g. { "recordId": "abc123", "fileName": "CBC_Jan2025.pdf" }
  // e.g. { "prescriptionId": "xyz", "drugAdded": "Warfarin", "interaction": true }
  details    Json?

  // Network info
  ipAddress  String?
  userAgent  String?

  // Timestamp
  createdAt  DateTime    @default(now())

  @@index([userId])
  @@index([patientId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================
// APPOINTMENTS (Telehealth)
// ============================================================

model Appointment {
  id               String            @id @default(cuid())
  patientId        String
  patient          Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId         String
  doctor           Doctor            @relation(fields: [doctorId], references: [id])

  scheduledAt      DateTime
  durationMinutes  Int               @default(30)

  status           AppointmentStatus @default(SCHEDULED)

  appointmentType  String            @default("TELEHEALTH") // "TELEHEALTH" | "IN_PERSON"

  // Telehealth meeting
  meetingLink      String?           // Video call link (e.g. Jitsi)
  meetingRoomId    String?

  // Consultation
  consultationFee  Decimal?          @db.Decimal(8, 2)
  chiefComplaint   String?           // Reason for visit
  doctorNotes      String?           // Notes added after appointment

  // Cancellation
  cancelledBy      String?           // userId
  cancellationReason String?
  cancelledAt      DateTime?

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@map("appointments")
}

// ============================================================
// FAMILY LINKS
// ============================================================

model FamilyLink {
  id                String          @id @default(cuid())

  // The account holder (parent/guardian/primary member)
  primaryPatientId  String
  primaryPatient    Patient         @relation("PrimaryPatient", fields: [primaryPatientId], references: [id], onDelete: Cascade)

  // The linked family member (e.g. child, elderly parent)
  linkedPatientId   String
  linkedPatient     Patient         @relation("LinkedPatient", fields: [linkedPatientId], references: [id], onDelete: Cascade)

  relationship      String          // e.g. "Son", "Mother", "Spouse"
  accessType        FamilyAccessType @default(VIEW)

  // For minors: is primary patient the legal guardian?
  isGuardian        Boolean         @default(false)

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Prevent duplicate links
  @@unique([primaryPatientId, linkedPatientId])
  @@map("family_links")
}
